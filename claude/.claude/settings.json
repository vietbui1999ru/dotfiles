{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "teammateMode": "in-process",
    "MAX_THINKING_TOKENS": "10000",
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet"
  },
  "permissions": {
    "allow": [
      "Bash(~/.claude/plugins/cache/claude-plugins-official/superpowers/*/skills/brainstorming/scripts/start-server.sh:*)",
      "mcp__sentry__authenticate",
      "mcp__sentry__complete_authentication"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/context-threshold-check.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/enforce-agent-whitelist.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/protect-lint-configs.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/enforce-bash-safety.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/context-threshold-notify.sh"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/observe-session.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cd ~/repos/llm-wiki && git diff --name-only HEAD 2>/dev/null | grep -q 'log\\.md' && ./scripts/publish-ai-kb.sh || true"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/lint-on-write.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/judge-reminder.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/lint-autofix.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "learning-output-style@claude-plugins-official": true,
    "sentry@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": false,
    "omnisharp@claude-code-lsps": false,
    "ralph-loop@claude-plugins-official": true,
    "basedpyright@claude-code-lsps": false,
    "clangd@claude-code-lsps": false,
    "gopls@claude-code-lsps": false,
    "ocaml-lsp@claude-code-lsps": false,
    "ruby-lsp@claude-code-lsps": false,
    "rust-analyzer@claude-code-lsps": false,
    "vscode-langservers@claude-code-lsps": false,
    "vtsls@claude-code-lsps": false,
    "pyright@claude-code-lsps": false,
    "typescript-lsp@claude-plugins-official": false,
    "caveman@caveman": true,
    "qmd@qmd": true,
    "graphql-lsp@claude-code-lsps": true,
    "haskell-language-server@claude-code-lsps": true,
    "jdtls@claude-code-lsps": true,
    "kotlin-lsp@claude-code-lsps": true,
    "lean4-lake-lsp@claude-code-lsps": true,
    "lean4-lean-lsp@claude-code-lsps": true,
    "mdbase-lsp@claude-code-lsps": true,
    "svelte-lsp@claude-code-lsps": true,
    "vue-volar@claude-code-lsps": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "qmd": {
      "source": {
        "source": "github",
        "repo": "tobi/qmd"
      }
    }
  },
  "effortLevel": "high",
  "tui": "fullscreen",
  "skipWorkflowUsageWarning": true,
  "editorMode": "vim",
  "verbose": true,
  "autoCompactEnabled": false,
  "teammateMode": "in-process",
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "mcpServers": {
    "shadcn": {
      "url": "https://www.shadcn.io/api/mcp"
    },
    "firecrawl": {
      "command": "bash",
      "args": [
        "-lc",
        "set -a; [ -f \"$HOME/secrets/.env\" ] && source \"$HOME/secrets/.env\"; exec npx -y firecrawl-mcp"
      ]
    }
  }
}
