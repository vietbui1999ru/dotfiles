#!/usr/bin/env bash
set -euo pipefail

topics=(
  bash
  zsh
  tmux
  git
  rg
  fd
  jq
  awk
  sed
  python
  go
  rust
  docker
  kubectl
)

die() {
  printf 'tmux-cht: %s\n' "$*" >&2
  exit 1
}

command -v curl >/dev/null 2>&1 || die 'curl is required'

cleanup_file=
cleanup_window=

cleanup() {
  if [ -n "${cleanup_window:-}" ] && command -v tmux >/dev/null 2>&1; then
    tmux rename-window "$cleanup_window" 2>/dev/null || true
  fi
  [ -n "${cleanup_file:-}" ] && rm -f "$cleanup_file"
}

contains_topic() {
  local item=$1
  local topic
  for topic in "${topics[@]}"; do
    [[ $topic == "$item" ]] && return 0
  done
  return 1
}

prompt_query() {
  local choice query

  if command -v fzf >/dev/null 2>&1; then
    choice=$(printf '%s\n' "${topics[@]}" | fzf \
      --prompt='cht.sh topic/query> ' \
      --height=40% \
      --border=rounded \
      --layout=reverse \
      --print-query | awk 'NF { value=$0 } END { print value }')
  else
    printf 'cht.sh topic/query: '
    IFS= read -r choice
  fi

  [ -n "${choice:-}" ] || return 1

  if contains_topic "$choice"; then
    printf '%s query: ' "$choice" >/dev/tty
    IFS= read -r query </dev/tty
    [ -n "${query:-}" ] && printf '%s/%s\n' "$choice" "$query" || printf '%s\n' "$choice"
  else
    printf '%s\n' "$choice"
  fi
}

guess_filetype() {
  case $1 in
    bash/*|bash|zsh/*|zsh) printf 'sh' ;;
    python/*|python) printf 'python' ;;
    go/*|go|golang/*|golang) printf 'go' ;;
    rust/*|rust) printf 'rust' ;;
    javascript/*|javascript|nodejs/*|nodejs) printf 'javascript' ;;
    typescript/*|typescript) printf 'typescript' ;;
    lua/*|lua) printf 'lua' ;;
    c/*|c) printf 'c' ;;
    cpp/*|cpp|c++/*|c++) printf 'cpp' ;;
    docker/*|docker) printf 'dockerfile' ;;
    kubectl/*|kubectl) printf 'yaml' ;;
    *) printf 'text' ;;
  esac
}

show_result() {
  local file=$1 query=$2 filetype=$3 old_window

  cleanup_file=$file

  if [ -n "${TMUX:-}" ] && command -v tmux >/dev/null 2>&1; then
    old_window=$(tmux display-message -p '#W' 2>/dev/null || true)
    cleanup_window=$old_window
    tmux rename-window "cht:${query%%/*}" 2>/dev/null || true
  fi

  trap cleanup EXIT

  case ${TMUX_CHT_VIEWER:-auto} in
    cat)
      cat "$file"
      return
      ;;
    less)
      command -v less >/dev/null 2>&1 && less -FRX "$file" && return
      ;;
    vim)
      if command -v nvim >/dev/null 2>&1; then
        nvim -R \
          +'setlocal buftype=nofile bufhidden=wipe noswapfile nomodifiable nowrap nonumber norelativenumber signcolumn=no' \
          +"setlocal filetype=${filetype}" \
          "$file"
        return
      fi
      command -v vim >/dev/null 2>&1 && vim -R \
        +'setlocal buftype=nofile bufhidden=wipe noswapfile nomodifiable nowrap nonumber norelativenumber' \
        +"setlocal filetype=${filetype}" \
        "$file" && return
      ;;
  esac

  if command -v nvim >/dev/null 2>&1; then
    nvim -R \
      +'setlocal buftype=nofile bufhidden=wipe noswapfile nomodifiable nowrap nonumber norelativenumber signcolumn=no' \
      +"setlocal filetype=${filetype}" \
      "$file"
  elif command -v vim >/dev/null 2>&1; then
    vim -R \
      +'setlocal buftype=nofile bufhidden=wipe noswapfile nomodifiable nowrap nonumber norelativenumber' \
      +"setlocal filetype=${filetype}" \
      "$file"
  elif command -v less >/dev/null 2>&1; then
    less -FRX "$file"
  else
    cat "$file"
  fi
}

if [ "$#" -gt 0 ]; then
  if [ "$#" -gt 1 ] && contains_topic "$1"; then
    topic=$1
    shift
    query="$topic/$*"
  else
    query="$*"
  fi
else
  query=$(prompt_query) || exit 0
fi

encoded=${query// /+}
url="https://cht.sh/${encoded}?T"
tmpfile=$(mktemp "${TMPDIR:-/tmp}/tmux-cht.XXXXXX")

{
  printf '# cht.sh/%s\n' "$query"
  printf '# %s\n' "$url"
  printf '# Vim: / search, y yank, q quit. Text is plain for copy/paste.\n\n'
  curl -fsSL "$url"
} >"$tmpfile" || die "failed to fetch $url"

show_result "$tmpfile" "$query" "$(guess_filetype "$query")"
