#!/usr/bin/env bash
set -euo pipefail

topics=(
  bash zsh fish
  tmux git curl wget
  rg fd fzf jq awk sed grep xargs
  python python3 ruby perl php
  go rust c cpp java kotlin swift
  javascript typescript nodejs
  lua vim nvim
  docker docker-compose kubectl helm
  terraform ansible
  ssh openssl gpg
  make cmake
  systemd cron
  mysql postgres sqlite redis
  nginx apache
)

die() {
  printf 'tmux-cht: %s\n' "$*" >&2
  exit 1
}

command -v curl >/dev/null 2>&1 || die 'curl is required'

cleanup_file=

cleanup() {
  [ -n "${cleanup_file:-}" ] && rm -f "$cleanup_file"
}

contains_topic() {
  local item=$1 topic
  for topic in "${topics[@]}"; do
    [[ $topic == "$item" ]] && return 0
  done
  return 1
}

prompt_query() {
  local choice query

  if command -v fzf >/dev/null 2>&1; then
    choice=$(printf '%s\n' "${topics[@]}" | fzf \
      --prompt='cht.sh> ' \
      --height=50% \
      --border=rounded \
      --layout=reverse \
      --bind 'change:first' \
      --print-query | awk 'NF { value=$0 } END { print value }')
  else
    printf 'cht.sh topic/query: '
    IFS= read -r choice
  fi

  [ -n "${choice:-}" ] || return 1

  if contains_topic "$choice"; then
    printf '%s query: ' "$choice" >/dev/tty
    IFS= read -r query </dev/tty
    [ -n "${query:-}" ] && printf '%s/%s\n' "$choice" "$query" || printf '%s\n' "$choice"
  else
    printf '%s\n' "$choice"
  fi
}

guess_filetype() {
  case $1 in
    bash/*|bash|zsh/*|zsh|fish/*|fish) printf 'sh' ;;
    python/*|python|python3/*|python3) printf 'python' ;;
    ruby/*|ruby) printf 'ruby' ;;
    go/*|go|golang/*|golang) printf 'go' ;;
    rust/*|rust) printf 'rust' ;;
    javascript/*|javascript|nodejs/*|nodejs) printf 'javascript' ;;
    typescript/*|typescript) printf 'typescript' ;;
    lua/*|lua) printf 'lua' ;;
    c/*|c) printf 'c' ;;
    cpp/*|cpp|c++/*|c++) printf 'cpp' ;;
    java/*|java) printf 'java' ;;
    kotlin/*|kotlin) printf 'kotlin' ;;
    docker/*|docker) printf 'dockerfile' ;;
    kubectl/*|kubectl|helm/*|helm) printf 'yaml' ;;
    terraform/*|terraform) printf 'hcl' ;;
    *) printf 'text' ;;
  esac
}

show_result() {
  local file=$1 query=$2 filetype=$3

  cleanup_file=$file
  trap cleanup RETURN

  # guard: skip empty fetches
  local content_lines
  content_lines=$(grep -c . "$file" 2>/dev/null || echo 0)
  if [ "$content_lines" -le 3 ]; then
    printf '\n  [no results for: %s]\n\n  Press enter to continue...' "$query"
    read -r _
    return
  fi

  if command -v nvim >/dev/null 2>&1; then
    nvim -R \
      +'setlocal buftype=nofile bufhidden=wipe noswapfile nomodifiable nowrap nonumber norelativenumber signcolumn=no' \
      +"setlocal filetype=${filetype}" \
      "$file"
  elif command -v vim >/dev/null 2>&1; then
    vim -R \
      +'setlocal buftype=nofile bufhidden=wipe noswapfile nomodifiable nowrap nonumber norelativenumber' \
      +"setlocal filetype=${filetype}" \
      "$file"
  elif command -v less >/dev/null 2>&1; then
    less -FRX "$file"
  else
    cat "$file"
  fi
}

fetch_and_show() {
  local query=$1
  local encoded tmpfile url
  encoded=${query// /+}
  url="https://cht.sh/${encoded}?T"
  tmpfile=$(mktemp "${TMPDIR:-/tmp}/tmux-cht.XXXXXX")

  {
    printf '# cht.sh/%s\n' "$query"
    printf '# %s\n' "$url"
    printf '# Vim: / search, y yank, :q quit.\n\n'
    curl -fsSL "$url"
  } >"$tmpfile" 2>/dev/null || { rm -f "$tmpfile"; die "failed to fetch $url"; }

  show_result "$tmpfile" "$query" "$(guess_filetype "$query")"
  rm -f "$tmpfile"
}

# one-shot mode: tmux-cht go channels
if [ "$#" -gt 0 ]; then
  if [ "$#" -gt 1 ] && contains_topic "$1"; then
    topic=$1; shift
    fetch_and_show "$topic/$*"
  else
    fetch_and_show "$*"
  fi
  exit 0
fi

# interactive loop
while true; do
  query=$(prompt_query) || break
  fetch_and_show "$query"
done
