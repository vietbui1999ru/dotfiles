#!/usr/bin/env bash
set -euo pipefail

# ── topics for cht.sh fzf picker ──────────────────────────────────────
cht_topics=(
  bash zsh fish
  tmux git curl wget
  rg fd fzf jq awk sed grep xargs
  python python3 ruby perl php
  go rust c cpp java kotlin swift
  javascript typescript nodejs
  lua vim nvim
  docker docker-compose kubectl helm
  terraform ansible
  ssh openssl gpg
  make cmake
  systemd cron
  mysql postgres sqlite redis
  nginx apache
)

# ── sources ───────────────────────────────────────────────────────────
sources=(
  "cht.sh   stackoverflow answers + cheatsheets"
  "tldr     community simplified man pages (GitHub)"
  "man      local man page"
)

# ── helpers ───────────────────────────────────────────────────────────
die()  { printf 'tmux-cht: %s\n' "$*" >&2; exit 1; }

pick() {
  local prompt=$1; shift
  printf '%s\n' "$@" | fzf \
    --prompt="$prompt " \
    --height=50% \
    --border=rounded \
    --layout=reverse \
    --bind 'change:first'
}

view() {
  local file=$1 ft=${2:-text}
  if command -v nvim >/dev/null 2>&1; then
    nvim -R \
      +'setlocal buftype=nofile bufhidden=wipe noswapfile nomodifiable nowrap nonumber norelativenumber signcolumn=no' \
      +"setlocal filetype=${ft}" \
      "$file"
  elif command -v less >/dev/null 2>&1; then
    less -FRX "$file"
  else
    cat "$file"
  fi
  rm -f "$file"
}

empty_guard() {
  local file=$1 query=$2
  local lines
  lines=$(grep -c . "$file" 2>/dev/null || echo 0)
  if [ "$lines" -le 3 ]; then
    printf '\n  [no results for: %s]\n\n  Press enter...' "$query"
    read -r _
    return 1
  fi
  return 0
}

guess_ft() {
  case $1 in
    bash*|zsh*|fish*) printf 'sh' ;;
    python*) printf 'python' ;;
    ruby*)   printf 'ruby' ;;
    go*)     printf 'go' ;;
    rust*)   printf 'rust' ;;
    js*|javascript*|node*) printf 'javascript' ;;
    typescript*) printf 'typescript' ;;
    lua*)    printf 'lua' ;;
    c|c/*)   printf 'c' ;;
    cpp*|c++*) printf 'cpp' ;;
    java/*)  printf 'java' ;;
    kotlin*) printf 'kotlin' ;;
    docker*) printf 'dockerfile' ;;
    kubectl*|helm*) printf 'yaml' ;;
    terraform*) printf 'hcl' ;;
    *) printf 'text' ;;
  esac
}

contains_cht_topic() {
  local item=$1 t
  for t in "${cht_topics[@]}"; do [[ $t == "$item" ]] && return 0; done
  return 1
}

# ── source handlers ───────────────────────────────────────────────────

do_chtsh() {
  local choice query
  choice=$(pick 'cht.sh>' "${cht_topics[@]}") || return 0

  if contains_cht_topic "$choice"; then
    printf '%s query (enter for overview): ' "$choice" >/dev/tty
    IFS= read -r query </dev/tty
    [ -n "${query:-}" ] && choice="${choice}/${query}"
  fi

  local encoded url tmp
  encoded=${choice// /+}
  url="https://cht.sh/${encoded}?T"
  tmp=$(mktemp "${TMPDIR:-/tmp}/tmux-cht.XXXXXX")

  {
    printf '# cht.sh/%s\n' "$choice"
    printf '# :q to quit, / to search\n\n'
    curl -fsSL "$url"
  } >"$tmp" 2>/dev/null || { rm -f "$tmp"; printf '\n  [fetch failed: %s]\n' "$url"; sleep 1; return 0; }

  empty_guard "$tmp" "$choice" && view "$tmp" "$(guess_ft "$choice")" || true
}

do_tldr() {
  local cmd
  printf 'tldr command: ' >/dev/tty
  IFS= read -r cmd </dev/tty
  [ -z "${cmd:-}" ] && return 0

  # normalise: "git worktree" → "git-worktree"
  local page=${cmd// /-}
  local tmp url content
  tmp=$(mktemp "${TMPDIR:-/tmp}/tmux-cht.XXXXXX")

  # try platforms in order
  local found=0
  for platform in common linux osx; do
    url="https://raw.githubusercontent.com/tldr-pages/tldr/main/pages/${platform}/${page}.md"
    content=$(curl -fsSL "$url" 2>/dev/null)
    if [ -n "$content" ] && ! printf '%s' "$content" | grep -q '404'; then
      found=1
      {
        printf '# tldr: %s  [%s]\n' "$cmd" "$platform"
        printf '# :q to quit, / to search\n\n'
        printf '%s\n' "$content"
      } >"$tmp"
      break
    fi
  done

  if [ "$found" -eq 0 ]; then
    rm -f "$tmp"
    printf '\n  [no tldr page for: %s]\n  Try cht.sh or man instead.\n\n  Press enter...' "$cmd"
    read -r _
    return 0
  fi

  view "$tmp" "markdown"
}

do_man() {
  local cmd section=""
  printf 'man command (e.g. git-worktree, curl, 5 crontab): ' >/dev/tty
  IFS= read -r cmd </dev/tty
  [ -z "${cmd:-}" ] && return 0

  local tmp
  tmp=$(mktemp "${TMPDIR:-/tmp}/tmux-cht.XXXXXX")

  # shellcheck disable=SC2086
  if ! man $cmd 2>/dev/null | col -bx >"$tmp"; then
    rm -f "$tmp"
    printf '\n  [no man page for: %s]\n\n  Press enter...' "$cmd"
    read -r _
    return 0
  fi

  {
    local header
    header=$(head -1 "$tmp")
    local body
    body=$(tail -n +2 "$tmp")
    printf '# man: %s\n' "$cmd"
    printf '# :q to quit, / to search\n\n'
    printf '%s\n' "$header"
    printf '%s\n' "$body"
  } >"${tmp}.fmt" && mv "${tmp}.fmt" "$tmp"

  view "$tmp" "man"
}

# ── one-shot mode ─────────────────────────────────────────────────────
if [ "$#" -gt 0 ]; then
  if [ "$#" -gt 1 ] && contains_cht_topic "$1"; then
    t=$1; shift; do_chtsh <<< "${t}/${*}"
  else
    SOURCE=chtsh
    choice="$*"
    encoded=${choice// /+}
    url="https://cht.sh/${encoded}?T"
    tmp=$(mktemp "${TMPDIR:-/tmp}/tmux-cht.XXXXXX")
    { printf '# cht.sh/%s\n# :q to quit\n\n' "$choice"; curl -fsSL "$url"; } >"$tmp"
    view "$tmp" "$(guess_ft "$choice")"
  fi
  exit 0
fi

# ── interactive loop ──────────────────────────────────────────────────
while true; do
  src=$(pick 'source>' "${sources[@]}") || break
  src_key=$(printf '%s' "$src" | awk '{print $1}')

  case $src_key in
    cht.sh) do_chtsh ;;
    tldr)   do_tldr ;;
    man)    do_man ;;
  esac
done
