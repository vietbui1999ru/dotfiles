#!/usr/bin/env python3
"""agent-workflow — idempotent attach/status/doctor for local AI workflow repos."""

from __future__ import annotations

import argparse
import json
import os
import shutil
import subprocess
import sys
from pathlib import Path
from typing import Any

SCRIPT = Path(__file__).resolve()
DOTFILES = SCRIPT.parents[1]
DEFAULT_CONFIG_PATH = DOTFILES / "shared" / "agent-workflow.default.json"
USER_CONFIG_PATH = Path(os.environ.get("AGENT_WORKFLOW_CONFIG", "~/.config/agent-workflow/config.json")).expanduser()
MANAGED_HOOK_MARKER = "agent-workflow managed: pre-commit-gate"
BUS_DIRS = ["inbox", "claimed", "done", "approvals", "council", "annotations"]
# Commandr's own bus home versions inbox/done via its own committed .gitignore;
# attached repos treat the whole bus as transient (nothing under .agents/ is
# committed here).
IGNORE_LINES = [
    ".agents/inbox/",
    ".agents/done/",
    ".agents/claimed/",
    ".agents/approvals/",
    ".agents/council/",
    ".agents/annotations/",
    ".agents/sessions/",
    ".agents/events.jsonl",
    ".diffviewer/",
    ".pi/",
    ".agent-workflow.local.json",
    ".obsidian/",
]


def die(message: str, code: int = 1) -> None:
    print(f"agent-workflow: {message}", file=sys.stderr)
    raise SystemExit(code)


def run(args: list[str], cwd: Path | None = None, check: bool = False) -> subprocess.CompletedProcess[str]:
    return subprocess.run(args, cwd=cwd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, check=check)


def load_json(path: Path) -> dict[str, Any]:
    if not path.exists():
        return {}
    try:
        with path.open() as f:
            data = json.load(f)
        return data if isinstance(data, dict) else {}
    except Exception as exc:  # noqa: BLE001 - CLI should report malformed config clearly.
        die(f"failed to parse {path}: {exc}")


def ensure_user_config() -> None:
    USER_CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
    if USER_CONFIG_PATH.exists():
        return
    if DEFAULT_CONFIG_PATH.exists():
        shutil.copyfile(DEFAULT_CONFIG_PATH, USER_CONFIG_PATH)
    else:
        USER_CONFIG_PATH.write_text(json.dumps(default_config(), indent=2) + "\n")
    print(f"✓ created {USER_CONFIG_PATH}")


def default_config() -> dict[str, Any]:
    return {
        "commandr": True,
        "preCommitGate": True,
        "diffviewer": True,
        "neovimCockpit": True,
        "piCockpit": True,
        "opencodeAdapters": True,
        "claudeHooks": False,
        "autoOpenNeovimBoard": False,
    }


def git_main_root(path: Path) -> Path:
    path = path.expanduser().resolve()
    if not path.exists():
        die(f"repo path does not exist: {path}")
    proc = run(["git", "-C", str(path), "rev-parse", "--git-common-dir"])
    if proc.returncode != 0:
        die(f"not inside a git repository: {path}")
    common = proc.stdout.strip()
    common_path = Path(common)
    if not common_path.is_absolute():
        common_path = (path / common_path).resolve()
    return common_path.parent.resolve()


def merged_config(repo: Path | None = None) -> dict[str, Any]:
    cfg = default_config()
    cfg.update(load_json(DEFAULT_CONFIG_PATH))
    cfg.update(load_json(USER_CONFIG_PATH))
    if repo is not None:
        root = git_main_root(repo)
        cfg.update(load_json(root / ".agent-workflow.json"))
        cfg.update(load_json(root / ".agent-workflow.local.json"))
    return cfg


def enabled(cfg: dict[str, Any], key: str) -> bool:
    return cfg.get(key) is not False


def append_ignore_lines(path: Path, lines: list[str]) -> bool:
    path.parent.mkdir(parents=True, exist_ok=True)
    existing = path.read_text().splitlines() if path.exists() else []
    to_add = [line for line in lines if line not in existing]
    if not to_add:
        return False
    with path.open("a") as f:
        for line in to_add:
            f.write(line + "\n")
    return True


def has_tracked_gitignore(root: Path) -> bool:
    proc = run(["git", "-C", str(root), "ls-files", "--error-unmatch", ".gitignore"])
    return proc.returncode == 0


def ensure_ignores(root: Path) -> None:
    if has_tracked_gitignore(root):
        changed = append_ignore_lines(root / ".gitignore", IGNORE_LINES)
        print(f"✓ .gitignore {'updated' if changed else 'already configured'}")
    else:
        exclude = root / ".git" / "info" / "exclude"
        changed = append_ignore_lines(exclude, IGNORE_LINES)
        print(f"✓ git excludes {'updated' if changed else 'already configured'}")


def install_pre_commit(root: Path) -> None:
    hook = root / ".git" / "hooks" / "pre-commit"
    hook.parent.mkdir(parents=True, exist_ok=True)
    desired = f"#!/bin/sh\n# {MANAGED_HOOK_MARKER}\nexec pre-commit-gate\n"
    if hook.exists():
        current = hook.read_text(errors="replace")
        if MANAGED_HOOK_MARKER not in current:
            print(f"⚠ custom pre-commit hook exists; not overwriting: {hook}")
            print("  install manually or remove the existing hook if you want the gate managed")
            return
    hook.write_text(desired)
    hook.chmod(0o755)
    print("✓ pre-commit gate installed")


def remove_pre_commit(root: Path) -> None:
    hook = root / ".git" / "hooks" / "pre-commit"
    if not hook.exists():
        print("✓ pre-commit gate absent")
        return
    current = hook.read_text(errors="replace")
    if MANAGED_HOOK_MARKER in current:
        hook.unlink()
        print("✓ managed pre-commit gate removed")
    else:
        print(f"⚠ custom pre-commit hook left untouched: {hook}")


def attach(args: argparse.Namespace) -> None:
    ensure_user_config()
    root = git_main_root(Path(args.repo))
    cfg = merged_config(root)
    print(f"Repo: {root}")

    if enabled(cfg, "commandr"):
        bus = root / ".agents"
        for name in BUS_DIRS:
            (bus / name).mkdir(parents=True, exist_ok=True)
        (bus / "events.jsonl").touch()
        # Universal session inbox
        (bus / "sessions").mkdir(parents=True, exist_ok=True)
        print("✓ Commandr bus attached (incl. sessions/)")
    else:
        print("- Commandr disabled by config")

    if enabled(cfg, "diffviewer"):
        (root / ".diffviewer" / "turns").mkdir(parents=True, exist_ok=True)
        print("✓ DiffViewer sidecar directory attached")
    else:
        print("- DiffViewer disabled by config")

    (root / ".pi" / "status").mkdir(parents=True, exist_ok=True)
    (root / ".pi" / "diff-review").mkdir(parents=True, exist_ok=True)
    print("✓ Pi runtime directory attached (status/, diff-review/)")

    ensure_ignores(root)

    if enabled(cfg, "preCommitGate"):
        install_pre_commit(root)
    else:
        print("- pre-commit gate disabled by config")

    status(args)


def detach(args: argparse.Namespace) -> None:
    root = git_main_root(Path(args.repo))
    print(f"Repo: {root}")
    remove_pre_commit(root)
    if args.remove_bus:
        shutil.rmtree(root / ".agents", ignore_errors=True)
        print("✓ .agents/ removed")
    else:
        print("✓ .agents/ kept")
    if args.remove_diffviewer:
        shutil.rmtree(root / ".diffviewer", ignore_errors=True)
        print("✓ .diffviewer/ removed")
    else:
        print("✓ .diffviewer/ kept")


def count_md(path: Path) -> int:
    return len(list(path.glob("*.md"))) if path.is_dir() else 0


def hook_state(root: Path) -> str:
    hook = root / ".git" / "hooks" / "pre-commit"
    if not hook.exists():
        return "missing"
    text = hook.read_text(errors="replace")
    return "managed" if MANAGED_HOOK_MARKER in text else "custom"


def status(args: argparse.Namespace) -> None:
    root = git_main_root(Path(args.repo))
    cfg = merged_config(root)
    bus = root / ".agents"
    print(f"\nStatus for {root}")
    print(f"  Commandr config: {'enabled' if enabled(cfg, 'commandr') else 'disabled'}")
    print(f"  Commandr bus: {'attached' if (bus / 'events.jsonl').exists() else 'missing'}")
    print(f"    inbox={count_md(bus / 'inbox')} claimed={count_md(bus / 'claimed')} done={count_md(bus / 'done')}")
    print(f"  pre-commit gate: {hook_state(root)}")
    print(f"  DiffViewer dir: {'attached' if (root / '.diffviewer' / 'turns').is_dir() else 'missing'}")
    print(f"  Neovim cockpit: {'enabled' if enabled(cfg, 'neovimCockpit') else 'disabled'}")
    print(f"  Pi cockpit: {'enabled' if enabled(cfg, 'piCockpit') else 'disabled'}")
    print(f"  OpenCode adapters: {'enabled' if enabled(cfg, 'opencodeAdapters') else 'disabled'}")
    print(f"  Claude hooks: {'enabled' if enabled(cfg, 'claudeHooks') else 'disabled'}")


def tool_line(name: str) -> str:
    found = shutil.which(name)
    return f"  {name}: {found or 'missing'}"


def doctor(_args: argparse.Namespace) -> None:
    ensure_user_config()
    print("agent-workflow doctor")
    print(f"  dotfiles: {DOTFILES}")
    print(f"  config: {USER_CONFIG_PATH}")
    print(f"  default config: {DEFAULT_CONFIG_PATH if DEFAULT_CONFIG_PATH.exists() else 'missing'}")
    for name in ["claim", "progress", "complete", "pre-commit-gate", "pi", "omp"]:
        print(tool_line(name))
    ext = Path("~/.pi/agent/extensions/neovim-cockpit.ts").expanduser()
    print(f"  Pi cockpit extension: {ext if ext.exists() else 'missing'}")
    oc_plugin = Path("~/.config/opencode/plugins/commandr-checkpoint.js").expanduser()
    print(f"  OpenCode Commandr plugin: {oc_plugin if oc_plugin.exists() else 'missing'}")
    print("  Neovim Lua syntax: run `luac -p` in validation (doctor is non-mutating)")


def show_config(args: argparse.Namespace) -> None:
    ensure_user_config()
    repo = Path(args.repo) if args.repo else None
    print(json.dumps(merged_config(repo), indent=2, sort_keys=True))


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Attach repos to the Commandr/Pi/Neovim agent workflow")
    sub = parser.add_subparsers(dest="command", required=True)

    p = sub.add_parser("attach", help="initialize workflow files in a repo")
    p.add_argument("repo", nargs="?", default=".")
    p.set_defaults(func=attach)

    p = sub.add_parser("detach", help="remove managed hooks; keep bus by default")
    p.add_argument("repo", nargs="?", default=".")
    p.add_argument("--remove-bus", action="store_true", help="delete .agents/ task history")
    p.add_argument("--remove-diffviewer", action="store_true", help="delete .diffviewer/ sidecars")
    p.set_defaults(func=detach)

    p = sub.add_parser("status", help="show repo workflow state")
    p.add_argument("repo", nargs="?", default=".")
    p.set_defaults(func=status)

    p = sub.add_parser("doctor", help="show global install checks")
    p.set_defaults(func=doctor)

    p = sub.add_parser("config", help="print merged config")
    p.add_argument("repo", nargs="?")
    p.set_defaults(func=show_config)
    return parser


def main() -> None:
    parser = build_parser()
    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
